# ============================================================
# Environment Variables — copy to .env.local and fill values
# ============================================================

# Runtime
NODE_ENV=development

# Public (safe to expose to browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# Server-only (never expose to client)
API_SECRET_KEY=change-me-at-least-32-characters-long
DATABASE_URL=postgresql://user:password@localhost:5432/va_portfolio

# Auth
AUTH_SECRET=change-me-at-least-32-characters-long
AUTH_TOKEN_EXPIRY_SECONDS=3600
